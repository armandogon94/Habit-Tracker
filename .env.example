# Habit Tracker - Environment Configuration
# Copy this file to .env.local for local development, or .env for production

# ============================================
# Backend API Configuration
# ============================================
# Port mapping (host port → container port)
# Development: 8020:8000
# Production: via Traefik on api.habits.305-ai.com
BACKEND_PORT=8020

# PostgreSQL connection string
# Project 02 uses database: habits_db
# Shared PostgreSQL instance on VPS
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@localhost:5432/habits_db

# JWT secret for authentication (minimum 32 characters)
JWT_SECRET=your-secret-key-here-min-32-chars-required

# Redis connection for caching
# Project 02 uses Redis DB number 2 (see PORT-MAP.md)
REDIS_URL=redis://localhost:6379/2

# Logging level
LOG_LEVEL=info

# ============================================
# Frontend Configuration
# ============================================
# Port mapping (host port → container port)
# Development: 3020:3000
# Production: via Traefik on habits.305-ai.com
FRONTEND_PORT=3020

# API URL for frontend to connect to backend
# Development: http://localhost:8020
# Production: https://api.habits.305-ai.com
NEXT_PUBLIC_API_URL=http://localhost:8020

# ============================================
# Docker Compose
# ============================================
# Use docker-compose.yml for development
# Use docker-compose.prod.yml for production with Traefik

# Start development stack:
#   docker-compose up -d

# Start production stack:
#   docker-compose -f docker-compose.prod.yml up -d
